# Mapbox (Index-Karte) — Pflicht
# https://account.mapbox.com/access-tokens/ → "Create a token" → Scopes: styles:read, tiles:read, fonts:read
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# Google Map Tiles API — Photorealistic 3D Tiles für /welt-Route
# Setup: console.cloud.google.com → "Map Tiles API" aktivieren → API-Key mit HTTP-Referrer-Restriction
# Pflicht-Restriction: http://localhost:* + https://*.vercel.app/* + https://DEINE-DOMAIN/*
# Pflicht-API-Restriction: nur "Map Tiles API"
# Pricing: 1.000 Root-Tile-Sessions/Monat gratis (Enterprise-Tier)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-tile-api-key

# OpenAI gpt-image-1 — Vision-Tab im DetailPanel (server-only!)
# https://platform.openai.com/api-keys → "Restricted" Key → nur "Images: Write"
# Pricing: gpt-image-1 Standard 1024x1024 ≈ $0.04/Image
OPENAI_API_KEY=your-openai-server-key

# Vercel Blob — Vision-Image-Cache in Production (in dev: in-memory)
# Dashboard → Storage → Create Blob Store → Quickstart-Tab
# In Vercel-Deploys automatisch injected, hier nur für local-dev nötig
BLOB_READ_WRITE_TOKEN=

# Cost-Hard-Caps (optional, default greift wenn leer)
OPENAI_DAILY_BUDGET_USD=2.00
GOOGLE_TILES_DAILY_SESSION_CAP=2000
